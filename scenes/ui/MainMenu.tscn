[node name="HowToPlayPanel" type="PanelContainer" parent="CanvasLayer/UI"]
visible = false
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -300.0
offset_top = -200.0
offset_right = 300.0
offset_bottom = 200.0
grow_horizontal = 2
grow_vertical = 2

[node name="Instructions" type="RichTextLabel" parent="CanvasLayer/UI/HowToPlayPanel"]
layout_mode = 2
bbcode_enabled = true
text = "[b]How to Play[/b]

- Move pieces to capture opponent pieces
- Capturing is mandatory!
- After capture, find chains of 5+ attacking pieces
- Chain pieces are removed and you earn points
- Spawn 3 new pieces after each chain

[b]Chain Rules:[/b]
- Pieces must alternate colors (W-B-W-B)
- Each piece must attack the next
- Longer chains = more points!

[b]Scoring:[/b]
- 100 points per removed piece
- +50% for 5-piece chain
- +100% for 6+ pieces
- +200% for 7+ pieces

Press ESC to close"

[node name="CloseButton" type="Button" parent="CanvasLayer/UI/HowToPlayPanel"]
layout_mode = 2
text = "Close"