[node name="Instructions" type="RichTextLabel" parent="HowToPlayPanel/HowToPlayCenter/InstructionsContainer" unique_id=191542519]
custom_minimum_size = Vector2(0, 520)
layout_mode = 2
size_flags_vertical = 3
theme_override_font_sizes/normal_font_size = 36
bbcode_enabled = true
text = "[b]Goal:[/b]
Move chess pieces to create lines of 5 or more matching pieces to clear them and score points.

[b]Movement:[/b]
- Click a piece to select it
- Valid empty cells are highlighted
- Click a highlighted cell to move
- Pieces move by chess-inspired rules

[b]Clearing Lines:[/b]
[color=RED]Color line:[/color] 5 or more pieces of the same color
[color=GREEN]Type line:[/color] 5 or more pieces of the same type
[color=YELLOW]Combo:[/color] A line that matches both color and type

[b]Turn Flow:[/b]
- Start with 3 random pieces
- After each move, 3 more pieces spawn
- If the board fills up or no meaningful moves remain, the game ends

Press [b]Esc[/b] or click [b]Back[/b] to return."

