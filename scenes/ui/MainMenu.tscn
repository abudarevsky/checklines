[node name="HowToPlayButton" type="Button" parent="CanvasLayer/UI/Menu"]
layout_mode = 2
size_flags_horizontal = 3
text = "How to Play"

[node name="QuitButton" type="Button" parent="CanvasLayer/UI/Menu"]
layout_mode = 2
size_flags_horizontal = 3
